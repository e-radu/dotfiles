format = """
[в•ӯ](fg:current_line)\
$os\
$username\
$directory\
$fill\
$python\
$c\
$cmd_duration\
$git_branch\
$line_break\
$character\
"""

palette = 'gruvbox'
add_newline = true

[palettes.gruvbox]
foreground = '#ebddb2'
background = '#3c3836'
current_line = '#3c3836'
primary = '#1E1F29'
box = '#3c3836'
blue	= '#6272A4'
cyan = '#8BE9FD'
green	= '#98971a'
orange = '#fe8019'
pink = '#FF79C6'
purple = '#BD93F9'
red	= '#FF5555'
yellow = '#fabd2f'

[os]
{{- if eq .chezmoi.os "windows" }}
format = '(fg:current_line)[оӮ¶](fg:blue)[$symbol ](fg:primary bg:blue)'
{{- else }}
format = '(fg:current_line)[оӮ¶](fg:orange)[$symbol ](fg:primary bg:orange)'
{{- end }}
disabled = false

[username]
format = '(fg:yellow bg:box)[ $user](fg:foreground bg:box)[оӮҙ](fg:box)'
show_always = true

[os.symbols]
Alpine = 'пҢҖ'
Amazon = 'пү°'
Android = 'оңҺ'
Arch = 'пҢғ'
CentOS = 'пҢ„'
Debian = 'пҢҶ'
EndeavourOS = 'пҢў'
Fedora = 'пҢҠ'
FreeBSD = 'пҢҢ'
Garuda = 'п…ј'
Gentoo = 'пҢҚ'
Linux = 'п…ј'
Macos = 'пҢӮ'
Manjaro = 'пҢ’'
Mariner = 'п…ј'
Mint = 'пҢҺ'
NetBSD = 'п…ј'
NixOS = 'пҢ“'
OpenBSD = 'пҢЁ'
OpenCloudOS = 'о®Ә'
openEuler = 'п…ј'
openSUSE = 'пҢ”'
OracleLinux = 'вҠӮвҠғ'
Pop = 'пҢӘ'
Raspbian = 'пҢ•'
Redhat = 'пҢ–'
RedHatEnterprise = 'пҢ–'
Solus = 'пҢӯ'
SUSE = 'пҢ”'
Ubuntu = 'пҢӣ'
Unknown = 'п„Ҳ'
Windows = 'оңҸ'

[directory]
format = '[в”Җ](fg:current_line)[оӮ¶](fg:yellow)[у°·Ҹ ](fg:primary bg:yellow)[оӮҙ](fg:yellow bg:box)[ $read_only$truncation_symbol$path](fg:foreground bg:box)[оӮҙ](fg:box)'
home_symbol = "оӯҶ ~/"
truncation_symbol = 'оҜҹ '
truncation_length = 2
read_only = 'уұ§ө '
read_only_style = ''

[git_branch]
format = '[в”Җ](fg:current_line)[оӮ¶](fg:green)[$symbol](fg:primary bg:green)[оӮҙ](fg:green bg:box)[ $branch](fg:foreground bg:box)[оӮҙ](fg:box)'
symbol = 'пҗ—'
truncation_length = 16
truncation_symbol = ''

[python]
format = '[в”Җ](fg:current_line)[оӮ¶](fg:green)[$symbol](fg:primary bg:green)[оӮҙ](fg:green bg:box)[ $virtualenv](fg:foreground bg:box)[оӮҙ](fg:box)'
symbol = 'оңј'

[c]
format = '[в”Җ](fg:current_line)[оӮ¶](fg:blue)[$symbol](fg:primary bg:blue)[оӮҙ](fg:blue bg:box)[ $version](fg:foreground bg:box)[оӮҙ](fg:box)'
symbol = 'оҳһ'

[fill]
symbol = 'в”Җ'
style = 'fg:current_line'

[cmd_duration]
min_time = 500
format = '[в”Җ](fg:current_line)[оӮ¶](fg:orange)[пғ§](fg:primary bg:orange)[оӮҙ](fg:orange bg:box)[ $duration ](fg:foreground bg:box)[оӮҙ](fg:box)'

[shell]
format = '[в”Җ](fg:current_line)[оӮ¶](fg:blue)[п’ү](fg:primary bg:blue)[оӮҙ](fg:blue bg:box)[ $indicator](fg:foreground bg:box)[оӮҙ](fg:box)'
unknown_indicator = 'sh'
disabled = false

[character]
format = """
[в•°в”Җ$symbol](fg:current_line) """
success_symbol = '[>](fg:bold white)'
error_symbol = '[Г—](fg:bold red)'
